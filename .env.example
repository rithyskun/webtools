WEBHOOK_SECRET=b4b8744347dc5ea8455f6b18b3d8af93a54868b48279ea397e01638d4e6113fa

# CORS - Comma-separated list of allowed origins (leave empty to allow all origins)
# For development, add: http://localhost:3000
# For production, add your domain: https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://anotherdomain.com

NODE_ENV=production

# Logging
LOG_RETENTION_DAYS=7

# API Keys (comma-separated, optional - if empty, API key auth is disabled)
API_KEYS=your-api-key-1,your-api-key-2

# Google OAuth2 Credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SSO provider credentials (optional – used by NextAuth)
# secret used by NextAuth to encrypt sessions
NEXTAUTH_SECRET=some-long-random-string

# Auth0 (https://auth0.com)
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_ISSUER=https://your-tenant.auth0.com

# GitHub OAuth app credentials
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Gmail Tokens (get using: npm run gmail:token)
GMAIL_ACCESS_TOKEN=your-gmail-access-token
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token